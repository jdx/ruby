#!/bin/bash
set -euo pipefail

# One-time script to create -1 revision releases for all existing releases.
# This avoids rebuilding — it just copies the assets from the floating release.
# Safe to run multiple times — skips versions that already have a revision release.

# Only match floating releases (X.Y.Z or X.Y.Z-previewN etc), not existing revision tags (X.Y.Z-1)
releases=$(gh release list --limit 200 --json tagName --jq '.[].tagName' | grep -E '^[0-9]+\.[0-9]+\.[0-9]+(-[a-z]|$)' || true)

for version in $releases; do
  revision_tag="${version}-1"

  # Skip if any revision already exists for this version
  if gh release view "$revision_tag" &>/dev/null; then
    echo "Skipping $version (${revision_tag} already exists)"
    continue
  fi

  echo "Creating $revision_tag from $version..."

  # Clean up any partial previous attempt (draft release without assets)
  gh release delete "$revision_tag" --yes 2>/dev/null || true
  gh api -X DELETE "repos/{owner}/{repo}/git/refs/tags/${revision_tag}" 2>/dev/null || true

  # Get the existing release info
  release_info=$(gh release view "$version" --json body,targetCommitish,isPrerelease)
  body=$(echo "$release_info" | jq -r '.body')
  target=$(echo "$release_info" | jq -r '.targetCommitish')
  is_prerelease=$(echo "$release_info" | jq -r '.isPrerelease')

  prerelease_flag=""
  if [[ "$is_prerelease" == "true" ]]; then
    prerelease_flag="--prerelease"
  fi

  # Download assets to a temp dir
  tmpdir=$(mktemp -d)
  trap "rm -rf '$tmpdir'" EXIT
  gh release download "$version" --dir "$tmpdir" --pattern '*.tar.gz' --pattern '*.jsonl'

  if ! ls "$tmpdir"/*.tar.gz &>/dev/null; then
    echo "Skipping $version (no assets found)"
    rm -rf "$tmpdir"
    trap - EXIT
    continue
  fi

  # Create the revision release
  body_with_revision="${body}

**Build revision:** ${revision_tag}"

  gh release create "$revision_tag" \
    --title "$revision_tag" \
    --notes "$body_with_revision" \
    --target "$target" \
    --latest=false \
    $prerelease_flag \
    "$tmpdir"/*

  rm -rf "$tmpdir"
  trap - EXIT
  echo "Created $revision_tag"
done
