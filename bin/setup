#!/bin/bash
set -euo pipefail
set -x

DIRNAME="$(basename "$(pwd)")"
TAP_DIR="$(brew --repo)/Library/Taps/jdx/homebrew-$DIRNAME"

if brew tap | grep -F "jdx/$DIRNAME"; then
  brew untap "jdx/$DIRNAME" --force
fi
brew tap "jdx/$DIRNAME" .
rm -rf "$TAP_DIR"
if [[ "${CI:-}" == "true" ]]; then
  mkdir -p "$TAP_DIR"
  git archive HEAD | tar -x -C "$TAP_DIR"
else
  ln -sf "$(pwd)" "$TAP_DIR"
fi
